# Copia este archivo como ".env" (mismo directorio, junto al .exe compilado)
# y completa los valores reales. ".env" nunca se sube a git (ver .gitignore).

# Puerto donde escucha el servidor NexoPago
dmvc.server.port=8080

# Conexion FireDAC a Firebird (NEXOPAGODB.FDB)
database.path=F:\Proyectos\NexoPago\DataBase\NEXOPAGODB.FDB
database.user=SYSDBA
database.password=
database.charset=UTF8

# Secreto de firma JWT. Nunca lo dejes vacio ni uses el valor por defecto del
# framework ('D3lph1MVCFram3w0rk'): dotEnv.RequireKeys hace que el backend
# rechace arrancar si esta clave falta o esta vacia.
JWT_SECRET=

# Sincronizacion de productos con Helisa (POST /api/productos/sincronizar).
# La ruta de la base de datos Helisa se detecta sola via HConfig.pas
# (registro de Windows), no se configura aqui. Estas claves son opcionales:
# si faltan, el backend arranca igual y el endpoint de sincronizacion
# responde 503 con un mensaje claro en vez de fallar el arranque.
# Helisa exige un usuario propio de aplicacion (trigger RDB$HEPERMISO rechaza
# a SYSDBA); en este entorno se usa HELISAADMON, no las credenciales de
# NexoPagoDB.
HELISA_TABLE_PREFIX=INMA
helisa.user=HELISAADMON
helisa.password=
