  [MVCNameCase(ncCamelCase)]
  [MVCTable('ORDEN_COMPRA_DETALLE')]
  TOrdenCompraDetalle = class(TMVCActiveRecord)
  private
    // ORDEN_COMPRA_DETALLE ya tiene un trigger BEFORE INSERT que asigna
    // DETALLE_ID desde SEQ_ORDEN_COMPRA_DETALLE cuando llega NULL, igual que
    // la columna IDENTITY. No hace falta (y de hecho rompe el INSERT, ver
    // historial de este archivo) pasar el nombre del generador aqui: mismo
    // patron simple que USUARIO/PROVEEDOR/PRODUCTO.
    [MVCTableField('DETALLE_ID', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('ORDEN_ID')]
    fOrdenID: Int64;
    [MVCTableField('PRODUCTO_ID')]
    fProductoID: Int64;
    [MVCTableField('CANTIDAD')]
    fCantidad: Currency;
    [MVCTableField('PRECIO_UNITARIO')]
    fPrecioUnitario: Currency;
    // Calculado por Firebird (COMPUTED BY CANTIDAD * PRECIO_UNITARIO). Jamas
    // se inserta/actualiza desde Delphi (foReadOnly). NOTA: probamos
    // foAutoGenerated para releer el valor tras el INSERT (como con una PK),
    // pero rompe el INSERT: genera un RETURNING que el framework ejecuta con
    // .Execute en vez de .Open ("Cannot execute command returning result
    // sets"). No hace falta el valor fresco justo despues de crear la orden
    // (el POST no devuelve el detalle), asi que basta con foReadOnly.
    [MVCTableField('SUBTOTAL', [foReadOnly])]
    fSubtotal: Currency;
    // Consecutivo de PETRXXXX (linea del pedido de Helisa) del que salio esta
    // cantidad. Nullable: lineas de una orden que no viene de un pedido de
    // Helisa (o creadas antes de esta funcionalidad) no lo tienen. El numero
    // de pedido en si vive en ORDEN_COMPRA.NUMERO_PEDIDO_HELISA (cabecera).
    [MVCTableField('CONSECUTIVO_PEDIDO_HELISA')]
    fConsecutivoPedidoHelisa: NullableInt32;
    [MVCTableField('USUARIO_CREO_ID')]
    fUsuarioCreoID: NullableInt64;
    [MVCTableField('FECHA_CREACION', [foReadOnly])]
    fFechaCreacion: TDateTime;
    [MVCTableField('USUARIO_MODIFICO_ID')]
    fUsuarioModificoID: NullableInt64;
    [MVCTableField('FECHA_MODIFICACION')]
    fFechaModificacion: NullableTDateTime;
    [MVCTableField('ESTADO_REGISTRO')]
    fEstadoRegistro: String;
  public
    property ID: NullableInt64 read fID write fID;
    property OrdenID: Int64 read fOrdenID write fOrdenID;
    property ProductoID: Int64 read fProductoID write fProductoID;
    property Cantidad: Currency read fCantidad write fCantidad;
    property PrecioUnitario: Currency read fPrecioUnitario write fPrecioUnitario;
    property Subtotal: Currency read fSubtotal;
    property ConsecutivoPedidoHelisa: NullableInt32 read fConsecutivoPedidoHelisa write fConsecutivoPedidoHelisa;
    property UsuarioCreoID: NullableInt64 read fUsuarioCreoID write fUsuarioCreoID;
    property FechaCreacion: TDateTime read fFechaCreacion;
    property UsuarioModificoID: NullableInt64 read fUsuarioModificoID write fUsuarioModificoID;
    property FechaModificacion: NullableTDateTime read fFechaModificacion write fFechaModificacion;
    property EstadoRegistro: String read fEstadoRegistro write fEstadoRegistro;
  end;

