  // Empresa Helisa activa (fila unica: SINGLETON_LOCK tiene UNIQUE + CHECK a
  // nivel de BD). SINGLETON_LOCK no se mapea como propiedad publica: no
  // aporta valor al DTO, solo es un mecanismo de integridad en la tabla.
  [MVCNameCase(ncCamelCase)]
  [MVCTable('EMPRESA_ACTIVA')]
  TEmpresaActiva = class(TMVCActiveRecord)
  private
    [MVCTableField('EMPRESA_ACTIVA_ID', [foPrimaryKey, foAutoGenerated])]
    fID: NullableInt64;
    [MVCTableField('CODIGO_EMPRESA_HELISA')]
    fCodigoEmpresaHelisa: Integer;
    [MVCTableField('NOMBRE_EMPRESA')]
    fNombreEmpresa: String;
    [MVCTableField('USUARIO_CREO_ID')]
    fUsuarioCreoID: NullableInt64;
    [MVCTableField('FECHA_CREACION', [foReadOnly])]
    fFechaCreacion: TDateTime;
    [MVCTableField('USUARIO_MODIFICO_ID')]
    fUsuarioModificoID: NullableInt64;
    [MVCTableField('FECHA_MODIFICACION')]
    fFechaModificacion: NullableTDateTime;
  public
    property ID: NullableInt64 read fID write fID;
    property CodigoEmpresaHelisa: Integer read fCodigoEmpresaHelisa write fCodigoEmpresaHelisa;
    property NombreEmpresa: String read fNombreEmpresa write fNombreEmpresa;
    property UsuarioCreoID: NullableInt64 read fUsuarioCreoID write fUsuarioCreoID;
    property FechaCreacion: TDateTime read fFechaCreacion;
    property UsuarioModificoID: NullableInt64 read fUsuarioModificoID write fUsuarioModificoID;
    property FechaModificacion: NullableTDateTime read fFechaModificacion write fFechaModificacion;
  end;

  // Historial de cambios de EMPRESA_ACTIVA (auditoria, no CRUD: solo se
  // inserta, nunca se actualiza/elimina). No tiene columnas de auditoria
  // propias (USUARIO_CREO_ID/FECHA_CREACION/...): USUARIO_ID + FECHA_CAMBIO
  // ya cumplen ese rol, la fila entera ES el registro de auditoria.
  [MVCNameCase(ncCamelCase)]
  [MVCTable('EMPRESA_ACTIVA_HISTORIAL')]
  TEmpresaActivaHistorial = class(TMVCActiveRecord)
  private
    [MVCTableField('HISTORIAL_ID', [foPrimaryKey, foAutoGenerated])]
