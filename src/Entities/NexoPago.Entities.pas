  public
    property ID: NullableInt64 read fID write fID;
    property CodigoEmpresaAnterior: NullableInt32 read fCodigoEmpresaAnterior write fCodigoEmpresaAnterior;
    property NombreEmpresaAnterior: NullableString read fNombreEmpresaAnterior write fNombreEmpresaAnterior;
    property CodigoEmpresaNueva: Integer read fCodigoEmpresaNueva write fCodigoEmpresaNueva;
    property NombreEmpresaNueva: String read fNombreEmpresaNueva write fNombreEmpresaNueva;
    property UsuarioID: Int64 read fUsuarioID write fUsuarioID;
    property FechaCambio: TDateTime read fFechaCambio;
  end;

implementation

uses
  System.SysUtils;

constructor TOrdenCompra.Create;
begin
  inherited Create;
  fDetalles := TObjectList<TOrdenCompraDetalle>.Create(True);
end;

destructor TOrdenCompra.Destroy;
begin
  fDetalles.Free;
  inherited Destroy;
end;

procedure TOrdenCompra.OnAfterLoad;
var
  lList: TObjectList<TOrdenCompraDetalle>;
begin
  inherited;
  lList := TMVCActiveRecord.SelectRQL<TOrdenCompraDetalle>(Format('eq(ordenId,%d)', [ID.ValueOrDefault]), 1000);
  try
    fDetalles.Clear;
    fDetalles.AddRange(lList);
    lList.OwnsObjects := False;
  finally
    lList.Free;
  end;
end;

end.
